generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScenarioRun {
  id        Int      @id @default(autoincrement())
  scenario  String
  status    String   @default("completed")
  duration  Int
  createdAt DateTime @default(now())

  @@map("scenario_runs")
}
